    <string>Eir uses your location to find nearby healthcare clinics.</string>
    <key>NSLocalNetworkUsageDescription</key>
    <string>Eir uses the local network to transfer health records to your iPhone via QR code.</string>
    <key>NSBonjourServices</key>
    <array>
        <string>_eir-transfer._tcp</string>
    </array>
    <key>NSAppTransportSecurity</key>
    <dict>
        <key>NSAllowsArbitraryLoads</key>
        <true/>
    </dict>
    <key>NSHumanReadableCopyright</key>
    <string>Copyright © 2024-2026 Birger Moell. All rights reserved.</string>
    <key>LSApplicationCategoryType</key>
    <string>public.app-category.medical</string>

{
  "manifest_version": 3,
  "name": "Eir Health Data Tools",
  "version": "1.0.0",
  "description": "Download 1177 journals and record MyKanta page flows for integration research",
  "permissions": [
    "activeTab",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://journalen.1177.se/*",
    "https://*.kanta.fi/*",
    "https://*.suomi.fi/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://journalen.1177.se/*"],
      "js": ["data-transfer.js", "content.js"],
      "css": ["styles.css"],
      "run_at": "document_end"
    },
    {
      "matches": [
        "https://*.kanta.fi/*",
        "https://*.suomi.fi/*"
      ],
      "js": ["kanta-recorder.js"],
      "css": ["styles.css"],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["kanta-network-probe.js"],
      "matches": [
        "https://*.kanta.fi/*",
        "https://*.suomi.fi/*"
      ]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Eir Health Data Tools"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
